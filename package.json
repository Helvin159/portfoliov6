{
  "name": "portfoliov6",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@emailjs/browser": "^4.1.0",
    "@payloadcms/db-mongodb": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.85.1",
    "dotenv": "^16.4.1",
    "emailjs-com": "^3.2.0",
    "firebase": "^10.8.0",
    "firebase-admin": "^14.1.0",
    "next": "15.4.11",
    "payload": "^3.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sass": "^1.70.0",
    "sharp": "^0.34.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --port 3010",
    "build": "next build",
    "start": "next start",
    "payload": "payload",
    "generate:importmap": "PAYLOAD_SKIP_ENV_VALIDATION=true payload generate:importmap",
    "generate:types": "PAYLOAD_SKIP_ENV_VALIDATION=true payload generate:types",
    "migration:export:firestore": "payload run src/modules/migration/actions/exportFirestoreContent.ts",
    "migration:import": "payload run src/modules/migration/actions/importPayloadSeed.ts",
    "migration:validate": "payload run src/modules/migration/actions/validateMigrationSeed.ts",
    "test": "node --import tsx --test tests/*.test.ts tests/*.test.tsx",
    "typecheck": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  }
}
